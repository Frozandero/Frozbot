# Discord Bot Configuration
# Copy this file to .env and fill in your actual values

# Your Discord bot token from Discord Developer Portal
# Go to: https://discord.com/developers/applications -> Your App -> Bot -> Token
DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Optional: Guild ID for testing slash commands immediately
# Leave empty or comment out to sync commands globally (takes up to 1 hour)
# To get your Guild ID: Enable Developer Mode in Discord, right-click server name -> Copy Server ID
# DISCORD_GUILD_ID=YOUR_GUILD_ID_HERE

# Your Discord User ID (for the refresh command)
# Enable Developer Mode in Discord, right-click your username -> Copy User ID
OWNER_ID=YOUR_USER_ID_HERE

# Development server ID (where the refresh command will be visible)
# This is your personal server where you develop/test the bot
# Enable Developer Mode in Discord, right-click your dev server name -> Copy Server ID
DEV_SERVER_ID=YOUR_DEV_SERVER_ID_HERE

# LLM Provider Configuration
# Select which LLM provider to use: "gemini" (default), "xai" (Grok), or add more providers in the future
# LLM_PROVIDER=gemini

# Gemini API Key for AI chat functionality (required if LLM_PROVIDER=gemini)
# Get your API key from: https://makersuite.google.com/app/apikey
# Requires google-genai>=2.3.0 for the Gemini Interactions API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional: comma-separated Gemini text/image-input fallback models.
# Add ":minimal", ":low", ":medium", or ":high" to control thinking level.
# GEMINI_TEXT_IMAGE_MODELS=gemini-3.5-flash:low,gemini-3-flash-preview:low,gemini-2.5-pro:low,gemini-2.5-flash:low,gemini-3.1-flash-lite:minimal,gemini-2.5-flash-lite:minimal

# Optional: comma-separated Gemini image-output fallback models for /imagine.
# Requires API access to the listed image-generation models.
# GEMINI_IMAGE_MODELS=gemini-3.1-flash-image,gemini-2.5-flash-image

# xAI API Key for Grok AI chat functionality (required if LLM_PROVIDER=xai)
# Get your API key from: https://console.x.ai/team/default/api-keys
# XAI_API_KEY=YOUR_XAI_API_KEY_HERE

# Future provider API keys (uncomment when adding new providers):
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ElevenLabs API Key for TTS functionality
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE

# ElevenLabs Voice ID for TTS (optional, defaults to "JBFqnCBsd6RMkjVDRZzb")
# You can find voice IDs from: https://elevenlabs.io/app/voice-library
# ELEVENLABS_VOICE_ID=YOUR_VOICE_ID_HERE

# Message History Configuration
# Number of recent messages to fetch per user (1-50, default: 10)
MESSAGE_HISTORY_LIMIT=10

# How far back to search in channel history (100-10000, default: 10000)
MESSAGE_HISTORY_SEARCH_DEPTH=10000

# Censor toggle
CENSOR_MESSAGES=false

# Retry Button Settings
# Minutes before retry buttons expire (default: 5)
RETRY_BUTTON_EXPIRE_MINUTES=5

# Cooldowns
# Ask command cooldown in minutes (default: 30)
ASK_COMMAND_COOLDOWN_MINUTES=30
# Imagine command cooldown in minutes (default: 15)
IMAGINE_COMMAND_COOLDOWN_MINUTES=15
# Enable/disable imagine command (default: true)
# If false at startup or before `/refresh`, the slash command is not registered.
IMAGINE_ENABLE=true
# Enable/disable ask command (default: true)
# If false at startup or before `/refresh`, the slash command is not registered.
ASK_ENABLE=true
# Require explicit @mention to respond (default: false)
# If true, bot ignores reply pings (when users reply to bot's messages)
# If false, bot responds to both explicit @mentions and reply pings
REQUIRE_EXPLICIT_MENTION=false

# Channel Context and Summary
# Number of last channel messages to include as raw context (default: 10)
CHANNEL_CONTEXT_LAST=10
# Whether to include bot messages in the raw channel context (default: false)
CHANNEL_CONTEXT_INCLUDE_BOT_MESSAGES=false
# Whether to generate a short LLM summary of recent conversation (default: true)
CHANNEL_SUMMARY_ENABLE=true
# Number of messages to consider for summary generation (default: 50)
CHANNEL_SUMMARY_DEPTH=50
# Cache summary for this many minutes to avoid extra requests (default: 3)
CHANNEL_SUMMARY_TTL_MIN=3
